# PROTOKOLL SPEICHERN
# ═════════════════════════════════════════════════════════════
def speichere_protokoll():
    protokoll["abgeschlossen"] = datetime.now().isoformat()
    protokoll["fehler_total"]  = len(protokoll["fehler"])
    protokoll["warn_total"]    = len(protokoll["warnungen"])
    pfad = "output/pipeline_protokoll.json"
    with open(pfad, "w", encoding="utf-8") as f:
        json.dump(protokoll, f, indent=2, ensure_ascii=False,
                  default=str)
    return pfad


