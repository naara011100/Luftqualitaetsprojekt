if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="DWAE Pipeline – Luftqualität Zürich")
    parser.add_argument("--ab-phase",  type=int, default=1,
                        help="Ab Phase N starten (1-6)")
    parser.add_argument("--nur-phase", type=int, default=None,
                        help="Nur Phase N ausführen")
    args = parser.parse_args()

    start_gesamt = time.time()
    print("\n" + "=" * 60)
    print("DWAE PROJEKT – AUTOMATISIERTE PIPELINE")
    print("Thema: Einfluss von Wetter auf Luftqualität in Zürich")
    print(f"Gestartet: {datetime.now().strftime('%d.%m.%Y %H:%M:%S')}")
    print("=" * 60)

    # Bestimme welche Phasen laufen
    if args.nur_phase:
        phasen = [args.nur_phase]
    else:
        phasen = list(range(args.ab_phase, 7))

    print(f"\n  Ausführen: Phasen {phasen}")

    try:
        df_luft = df_wetter = df_clean_l = df_clean_w = df_final = None

        # Zwischen-Daten laden wenn ab Phase > 1
        if args.ab_phase > 1 and 1 not in phasen:
            log("Lade vorhandene Rohdaten...")
            try:
                df_luft   = pd.read_csv("data/raw/luftqualitaet_2023_roh.csv")
                df_wetter = pd.read_csv("data/raw/wetter_2023_roh.csv")
                log("Rohdaten geladen", "OK")
            except FileNotFoundError:
                log("Rohdaten fehlen – starte ab Phase 1", "WARN")
                phasen = list(range(1, 7))

        if args.ab_phase > 3 and 3 not in phasen:
            try:
                df_clean_l = pd.read_csv(
                    "data/processed/luftqualitaet_2023_clean.csv")
                df_clean_w = pd.read_csv(
                    "data/processed/wetter_2023_clean.csv")
                log("Bereinigte Daten geladen", "OK")
            except FileNotFoundError:
                log("Bereinigte Daten fehlen – starte ab Phase 3", "WARN")
                phasen = list(range(min(3, args.ab_phase), 7))

        if args.ab_phase > 4 and 4 not in phasen:
            try:
                df_final = pd.read_csv("data/processed/datensatz_final.csv")
                df_final["timestamp"] = pd.to_datetime(df_final["timestamp"])
                log("Finaler Datensatz geladen", "OK")
            except FileNotFoundError:
                log("Finaler Datensatz fehlt – starte ab Phase 4", "WARN")
                phasen = list(range(min(4, args.ab_phase), 7))

        # Pipeline ausführen
        if 1 in phasen:
            df_luft, df_wetter = phase1_datenbeschaffung()
        if 2 in phasen and df_luft is not None:
            phase2_eda(df_luft, df_wetter)
        if 3 in phasen and df_luft is not None:
            df_clean_l, df_clean_w = phase3_bereinigung(df_luft, df_wetter)
        if 4 in phasen and df_clean_l is not None:
            df_final = phase4_transformation(df_clean_l, df_clean_w)
        if 5 in phasen and df_final is not None:
            phase5_qualitaet(df_final)
        if 6 in phasen and df_final is not None:
            phase6_visualisierung(df_final)

    except Exception as e:
        log(f"KRITISCHER FEHLER: {e}", "ERR")
        traceback.print_exc()
        sys.exit(1)

    finally:
        pfad = speichere_protokoll()
        dauer = time.time() - start_gesamt
        print(f"\n{'='*60}")
        print(f"PIPELINE ABGESCHLOSSEN in {dauer:.1f}s")
        print(f"  Fehler:   {len(protokoll['fehler'])}")
        print(f"  Warnungen:{len(protokoll['warnungen'])}")
        print(f"  Protokoll: {pfad}")
        print(f"\n  Output-Dateien:")
        for f in sorted(Path("output").rglob("*.*")):
            print(f"    {f}")
        print("=" * 60)